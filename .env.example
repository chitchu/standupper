# ── Gemini (LLM) ────────────────────────────────────────────────────────────
# Required. Get from: aistudio.google.com → Get API key
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash

# ── Slack Bot ────────────────────────────────────────────────────────────────
# Required for server mode. Create app at: api.slack.com/apps
# Bot Token Scopes needed: commands, chat:write, im:write, im:read
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# ── App URL (for OAuth redirects) ────────────────────────────────────────────
# Set to your Railway/Render URL in production
APP_URL=http://localhost:3000
PORT=3000

# ── Google OAuth (Gmail + Calendar) ─────────────────────────────────────────
# Create OAuth 2.0 credentials at: console.cloud.google.com
# App type: Web application
# Scopes: gmail.readonly, calendar.readonly
# Redirect URI: ${APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── GitLab OAuth ─────────────────────────────────────────────────────────────
# Create OAuth app at: gitlab.com/-/profile/applications
# Redirect URI: ${APP_URL}/auth/gitlab/callback
# Scope: read_api
GITLAB_CLIENT_ID=your_gitlab_app_id
GITLAB_CLIENT_SECRET=your_gitlab_app_secret
# GITLAB_URL=https://gitlab.com    # Override for self-hosted GitLab

# ── Jira OAuth 2.0 (Atlassian) ───────────────────────────────────────────────
# Create OAuth app at: developer.atlassian.com/console/myapps
# Redirect URI: ${APP_URL}/auth/jira/callback
# Scopes: read:jira-work offline_access
JIRA_CLIENT_ID=your_atlassian_client_id
JIRA_CLIENT_SECRET=your_atlassian_client_secret

# ── CLI-only env vars (legacy, not needed in server mode) ────────────────────
# These are used when running `npm run standup` directly (no Slack bot).
# GITLAB_TOKEN=glpat-xxxx
# GITLAB_USER_ID=1234567
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=you@yourcompany.com
# JIRA_API_TOKEN=ATATT3xFf...
# JIRA_ACCOUNT_ID=5b10ac8d82e05b22cc7d4ef5
# SLACK_USER_TOKEN=xoxp-xxxx
# SLACK_USER_ID=U0123ABCDEF
# GMAIL_CLIENT_ID=xxxx.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=GOCSPX-xxxx
# GMAIL_REFRESH_TOKEN=1//0g...
# GCAL_CLIENT_ID=xxxx.apps.googleusercontent.com
# GCAL_CLIENT_SECRET=GOCSPX-xxxx
# GCAL_REFRESH_TOKEN=1//0g...
